# Public Next.js site — local dev
# Base URL of the Bellas FastAPI backend. Used by the data layer (src/lib/api.ts)
# once Phase 4 rewires it off Payload. Server-only calls may use API_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000

# NOTE (baseline): the app currently still uses Payload/Prisma. These vars take
# effect in Phase 4 when the frontend is rewired to the backend public API.
