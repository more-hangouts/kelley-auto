# Public Next.js site — local dev
# Base URL of the Kelley FastAPI backend. Used by the data layer (src/lib/api.ts)
# once Phase 4 rewires it off Payload. Server-only calls may use API_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000

# Google Analytics 4 (gtag.js) measurement ID. Optional. When set, the tag
# loads on every page; leave empty to disable analytics in this environment.
NEXT_PUBLIC_GA_ID=
