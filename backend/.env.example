# Database
DATABASE_URL=postgresql://bellas_xv_user:bellas_xv_pass@localhost:5432/bellas_xv

# Application
APP_TIMEZONE=America/Chicago
APP_ENV=development
LOG_LEVEL=INFO

# Auth
SECRET_KEY=replace-with-output-of-python-secrets-token_urlsafe-48
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SESSION_COOKIE_DOMAIN=.shopbellasxv.com

# Frontend
CORS_ORIGINS=http://localhost:5173,https://sales.shopbellasxv.com

# Sales Portal local-dev override. Production routes by hostname:
# `admin.shopbellasxv.com` mounts the admin app, `sales.shopbellasxv.com`
# mounts the sales (PIN-login) app. To exercise the sales tree on
# localhost without DNS, set `VITE_FORCE_SUBDOMAIN=sales` in
# `frontend/.env.local` and `npm run dev`. Leave blank for admin.
# VITE_FORCE_SUBDOMAIN=

# Booking widget — public surface
PUBLIC_SITE_URL=http://localhost:5173
WIDGET_PUBLIC_BASE_URL=http://localhost:8000
PORTAL_BASE_URL=http://localhost:8000
BOOKING_WIDGET_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Booking widget — signed token secrets (rotate independently of SECRET_KEY)
RESCHEDULE_TOKEN_SECRET=replace-with-output-of-python-secrets-token_urlsafe-48
ENRICHMENT_TOKEN_SECRET=replace-with-output-of-python-secrets-token_urlsafe-48
ATTRIBUTION_COOKIE_DOMAIN=

# Booking widget — paid-ad conversion (server-side)
META_PIXEL_ID=
META_CAPI_TOKEN=
META_CAPI_TEST_EVENT_CODE=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Booking widget — product analytics
PLAUSIBLE_DOMAIN=

# Booking widget — outbound email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Bella's XV
SMTP_USE_TLS=true
BOOKING_INTERNAL_NOTIFICATION_EMAILS=

# Booking widget — outbound SMS (Twilio, wired in v1.5)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Event documents — local file storage. Override DOCUMENT_STORAGE_ROOT in dev
# or tests; production VPS owns /var/lib/bellas-xv/uploads via the API service
# user. DOCUMENT_STORAGE_BACKEND will get a real branch when object storage lands.
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_STORAGE_ROOT=/var/lib/bellas-xv/uploads
DOCUMENT_UPLOAD_MAX_MB=25

# Redis-backed rate limiter (Phase B1 of SECURITY_REMEDIATION_PLAN.md).
# Localhost Redis is bound to 127.0.0.1 only and not exposed externally.
# RATE_LIMIT_FAIL_OPEN: when Redis is unreachable, true allows the request
# with a warning log; false returns 503. Keep true during B1 rollout, flip
# to false once B2 wires a real route.
REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_FAIL_OPEN=true

# Integration-token at-rest encryption (Phase C1 of SECURITY_REMEDIATION_PLAN.md).
# Comma-separated Fernet keys, NEWEST FIRST. The first key encrypts new
# writes; every key in the list can decrypt. To rotate: prepend a new key,
# let traffic rewrite rows for one cycle, then drop the trailing old key.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_TOKEN_KEYS=

# Webhook event retention (Phase C2 of SECURITY_REMEDIATION_PLAN.md). The
# daily worker prunes `webhook_events` rows older than this. Default 90.
WEBHOOK_EVENTS_RETENTION_DAYS=90

# Quote signature HMAC (Phase C3 of SECURITY_REMEDIATION_PLAN.md). Single
# 32-byte hex secret used to stamp HMAC-SHA256 at quote-accept time.
# Rotation would invalidate every prior stamp — treat it as a separate
# slice if ever needed. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
QUOTE_SIGNATURE_KEY=
